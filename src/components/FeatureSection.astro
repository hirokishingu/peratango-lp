---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  image: string;
  alt: string;
  reverse?: boolean;
  note?: string;
}

const { eyebrow, title, description, image, alt, reverse = false, note } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class:list={['fs', { reverse }]}>
  <div class="inner">
    <div class="copy reveal">
      <span class="eyebrow">{eyebrow}</span>
      <h2>{title}</h2>
      <p>{description}</p>
      {note && <p class="note">{note}</p>}
    </div>
    <div class="mockup reveal">
      <div class="phone">
        <img
          src={`${base}${image}`}
          alt={alt}
          width="1179"
          height="2556"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .fs {
    padding: 5rem 2rem;
  }
  .inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .fs.reverse .inner {
    grid-template-columns: 1fr 1fr;
  }
  .fs.reverse .copy {
    order: 2;
  }
  .fs.reverse .mockup {
    order: 1;
  }
  .eyebrow {
    display: inline-block;
    padding: 0.3rem 0.7rem;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    margin: 0 0 1rem;
    letter-spacing: -0.01em;
  }
  p {
    font-size: 1.05rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.8;
  }
  .note {
    font-size: 0.8rem;
    color: var(--muted);
    opacity: 0.8;
    margin-top: 0.75rem;
    line-height: 1.6;
  }
  .mockup {
    display: flex;
    justify-content: center;
  }
  .phone {
    width: 260px;
    aspect-ratio: 9 / 19.5;
    border-radius: 40px;
    padding: 9px;
    background: linear-gradient(160deg, #1f2937, #0f172a);
    box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.25);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .phone:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 40px 70px -20px rgba(79, 70, 229, 0.3);
  }
  @media (prefers-reduced-motion: reduce) {
    .phone { transition: none; }
    .phone:hover { transform: none; }
  }
  .phone img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 30px;
    display: block;
  }
  @media (max-width: 768px) {
    .fs {
      padding: 3rem 1.5rem;
    }
    .inner,
    .fs.reverse .inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }
    .fs.reverse .copy {
      order: 1;
    }
    .fs.reverse .mockup {
      order: 2;
    }
  }
</style>

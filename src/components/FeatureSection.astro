---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  image: string;
  alt: string;
  reverse?: boolean;
  note?: string;
  /** 画像の動き: tilt (スクロール連動) / float / breathe / slide / parallax */
  motion?: 'tilt' | 'float' | 'breathe' | 'slide' | 'parallax';
  /** タップ演出の座標（画面内の %, 省略可）。例: '50,60' で中央やや下にタップ波紋 */
  tap?: string;
  /** スクロールヒント演出（画像が縦に少しだけ動く） */
  scrollHint?: boolean;
}

const {
  eyebrow,
  title,
  description,
  image,
  alt,
  reverse = false,
  note,
  motion = 'tilt',
  tap,
  scrollHint = false,
} = Astro.props;
const base = import.meta.env.BASE_URL;

let tapStyle = '';
if (tap) {
  const [x, y] = tap.split(',').map((s) => s.trim());
  tapStyle = `left: ${x}%; top: ${y}%;`;
}
---

<section class:list={['fs', { reverse }]}>
  <div class="inner">
    <div class="copy reveal">
      <span class="eyebrow">{eyebrow}</span>
      <h2>{title}</h2>
      <p>{description}</p>
      {note && <p class="note">{note}</p>}
    </div>
    <div class="mockup reveal">
      <div class={`phone motion-${motion}`} data-motion={motion}>
        <div class="viewport">
          <img
            class={scrollHint ? 'scroll-hint' : ''}
            src={`${base}${image}`}
            alt={alt}
            width="1179"
            height="2556"
            loading="lazy"
            decoding="async"
          />
          {tap && <span class="tap-ring" style={tapStyle} aria-hidden="true"></span>}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .fs {
    padding: 5rem 2rem;
  }
  .inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .fs.reverse .inner {
    grid-template-columns: 1fr 1fr;
  }
  .fs.reverse .copy {
    order: 2;
  }
  .fs.reverse .mockup {
    order: 1;
  }
  .eyebrow {
    display: inline-block;
    padding: 0.3rem 0.7rem;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    margin: 0 0 1rem;
    letter-spacing: -0.01em;
  }
  p {
    font-size: 1.05rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.8;
  }
  .note {
    font-size: 0.8rem;
    color: var(--muted);
    opacity: 0.8;
    margin-top: 0.75rem;
    line-height: 1.6;
  }
  .mockup {
    display: flex;
    justify-content: center;
  }

  /* --- Phone base --- */
  .phone {
    --tilt: 0deg;
    --scale: 1;
    --translate-y: 0px;
    --translate-x: 0px;
    width: 260px;
    aspect-ratio: 9 / 19.5;
    border-radius: 40px;
    padding: 9px;
    background: linear-gradient(160deg, #1f2937, #0f172a);
    box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.25);
    transition: box-shadow 0.4s ease;
    transform: translate(var(--translate-x), var(--translate-y)) rotate(var(--tilt)) scale(var(--scale));
  }
  .phone:hover {
    box-shadow: 0 40px 70px -20px rgba(79, 70, 229, 0.35);
  }
  .viewport {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 30px;
    overflow: hidden;
  }
  .phone img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* --- Motion variants --- */
  .motion-tilt {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.4s ease;
  }
  .motion-float {
    animation: phoneFloat 6s ease-in-out infinite;
  }
  .motion-breathe {
    animation: phoneBreathe 5s ease-in-out infinite;
  }
  .motion-slide {
    /* スライドは reveal 時に加算。通常時は静止 */
    transition: transform 0.9s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.4s ease;
  }
  .motion-parallax {
    transition: box-shadow 0.4s ease;
  }

  @keyframes phoneFloat {
    0%, 100% { transform: translateY(0) rotate(var(--tilt, 0deg)); }
    50% { transform: translateY(-12px) rotate(var(--tilt, 0deg)); }
  }
  @keyframes phoneBreathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); }
  }

  /* Slide 初期状態（reveal前）*/
  .reveal .motion-slide {
    opacity: 0;
    transform: translateX(-40px);
  }
  .reveal.in-view .motion-slide {
    opacity: 1;
    transform: translateX(0);
  }
  .fs.reverse .reveal .motion-slide {
    transform: translateX(40px);
  }
  .fs.reverse .reveal.in-view .motion-slide {
    transform: translateX(0);
  }

  /* --- Tap ring (simulated finger tap) --- */
  .tap-ring {
    position: absolute;
    width: 40px;
    height: 40px;
    margin-left: -20px;
    margin-top: -20px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(79, 70, 229, 0.55) 0%, rgba(79, 70, 229, 0) 70%);
    pointer-events: none;
    animation: tapPulse 2.4s ease-out infinite;
    z-index: 2;
  }
  @keyframes tapPulse {
    0% { transform: scale(0.3); opacity: 0; }
    20% { opacity: 1; }
    60% { transform: scale(1.8); opacity: 0.3; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  /* --- Scroll hint (image translateY loop) --- */
  .scroll-hint {
    animation: scrollLoop 7s ease-in-out infinite;
  }
  @keyframes scrollLoop {
    0%, 10% { transform: translateY(0); }
    45%, 55% { transform: translateY(-6%); }
    90%, 100% { transform: translateY(0); }
  }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    .motion-tilt,
    .motion-float,
    .motion-breathe,
    .motion-slide,
    .motion-parallax { animation: none; transition: none; transform: none; }
    .tap-ring { animation: none; display: none; }
    .scroll-hint { animation: none; }
  }

  @media (max-width: 768px) {
    .fs {
      padding: 3rem 1.5rem;
    }
    .inner,
    .fs.reverse .inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }
    .fs.reverse .copy {
      order: 1;
    }
    .fs.reverse .mockup {
      order: 2;
    }
  }
</style>

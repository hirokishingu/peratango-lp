---
// ヒーロー背景に漂う装飾絵文字レイヤー
---

<div class="floaters" aria-hidden="true">
  <span class="f f1">❄</span>
  <span class="f f2">🔥</span>
  <span class="f f3">📖</span>
  <span class="f f4">✨</span>
  <span class="f f5">🎤</span>
  <span class="f f6">✨</span>
</div>

<style>
  .floaters {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .f {
    position: absolute;
    font-size: 1.5rem;
    opacity: 0.35;
    filter: blur(0.4px);
    user-select: none;
  }
  .f1 { top: 12%; left: 6%; animation: drift1 14s ease-in-out infinite; font-size: 2rem; }
  .f2 { top: 62%; left: 8%; animation: drift2 18s ease-in-out infinite; font-size: 1.8rem; }
  .f3 { top: 22%; right: 8%; animation: drift3 16s ease-in-out infinite; font-size: 1.6rem; }
  .f4 { top: 72%; right: 12%; animation: drift4 12s ease-in-out infinite; font-size: 1.4rem; }
  .f5 { top: 40%; left: 50%; animation: drift5 20s ease-in-out infinite; font-size: 1.5rem; opacity: 0.2; }
  .f6 { top: 85%; left: 45%; animation: drift6 15s ease-in-out infinite; font-size: 1.2rem; }

  @keyframes drift1 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(20px, -30px) rotate(12deg); }
  }
  @keyframes drift2 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(30px, 20px) rotate(-8deg); }
  }
  @keyframes drift3 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(-25px, 25px) rotate(15deg); }
  }
  @keyframes drift4 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(-20px, -20px) rotate(-10deg); }
  }
  @keyframes drift5 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); opacity: 0.2; }
    50% { transform: translate(40px, -15px) rotate(20deg); opacity: 0.35; }
  }
  @keyframes drift6 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(-15px, -25px) rotate(-15deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .f { animation: none; }
  }
  @media (max-width: 768px) {
    .f { opacity: 0.25; }
    .f5, .f6 { display: none; }
  }
</style>

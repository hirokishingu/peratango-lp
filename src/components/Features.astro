---
interface Feature {
  icon: string;
  title: string;
  description: string;
}

const features: Feature[] = [
  {
    icon: '🧠',
    title: 'SRS で確実に記憶',
    description:
      '忘却曲線に基づいて最適なタイミングで復習。短時間でも長期記憶に定着します。',
  },
  {
    icon: '✨',
    title: 'AI が問題を自動生成',
    description:
      '登録した単語から AI がクイズを作成。意味・例文・使い方を多角的に学習。',
  },
  {
    icon: '📱',
    title: 'ウィジェット & ロック画面',
    description:
      'ホーム画面やロック画面から今日の単語をチェック。隙間時間を学習に変える。',
  },
  {
    icon: '📊',
    title: '進捗を見える化',
    description:
      '習得率・学習ストリーク・ロードマップで、続けるモチベーションを維持。',
  },
];
---

<section class="features">
  <div class="inner">
    <h2>主な機能</h2>
    <div class="grid">
      {
        features.map((f) => (
          <article class="card">
            <div class="icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features {
    padding: 4rem 2rem;
    background: var(--bg);
  }
  .inner {
    max-width: 960px;
    margin: 0 auto;
  }
  h2 {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin: 0 0 2.5rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .card {
    padding: 1.75rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg);
  }
  .icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }
  h3 {
    font-size: 1.125rem;
    margin: 0 0 0.5rem;
  }
  p {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }
</style>

---
interface Props {
  appStoreUrl?: string;
}

const { appStoreUrl = '#' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="inner">
    <div class="copy">
      <span class="eyebrow reveal">SRS × AI × ウィジェット</span>
      <h1 class="reveal">
        <span class="accent">忘れる前に</span>、<br />
        ちょうどいい復習を。
      </h1>
      <p class="reveal">
        フラッシュカード・AI クイズ・ロック画面ウィジェット。<br />
        科学的な間隔反復で、単語を確実に長期記憶へ。
      </p>
      <div class="actions reveal">
        <a href={appStoreUrl} class="cta">App Store で入手</a>
        <a href="#features" class="ghost">機能を見る</a>
      </div>
      <ul class="badges reveal">
        <li><span class="check">✓</span>完全無料</li>
        <li><span class="check">✓</span>広告なし</li>
        <li><span class="check">✓</span>登録不要</li>
        <li><span class="check">✓</span>オフライン対応</li>
      </ul>
    </div>
    <div class="mockup">
      <div class="phone floating">
        <img
          src={`${base}/screenshots/01_home.webp`}
          alt="PeraTango ホーム画面"
          width="1179"
          height="2556"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
  <div class="glow glow-a"></div>
  <div class="glow glow-b"></div>
</section>

<style>
  .hero {
    position: relative;
    padding: 5rem 2rem 6rem;
    overflow: hidden;
  }
  .inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .eyebrow {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 1.25rem;
  }
  h1 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }
  .accent {
    background: linear-gradient(
      135deg,
      #4f46e5 0%,
      #7c3aed 25%,
      #ec4899 50%,
      #7c3aed 75%,
      #4f46e5 100%
    );
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: gradientShift 8s ease-in-out infinite;
  }
  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .copy p {
    font-size: 1.1rem;
    color: var(--muted);
    margin: 0 0 2rem;
  }
  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .cta {
    display: inline-block;
    padding: 0.95rem 1.75rem;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    border-radius: 999px;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 10px 30px -10px color-mix(in srgb, var(--accent) 60%, transparent);
  }
  .cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px -12px color-mix(in srgb, var(--accent) 70%, transparent);
  }
  .ghost {
    display: inline-block;
    padding: 0.95rem 1.75rem;
    border: 1px solid var(--border);
    color: var(--fg);
    text-decoration: none;
    border-radius: 999px;
    font-weight: 600;
  }
  .badges {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
  }
  .badges li {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--muted);
    font-weight: 500;
  }
  .check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 700;
  }
  .mockup {
    display: flex;
    justify-content: center;
  }
  .phone {
    width: 280px;
    aspect-ratio: 9 / 19.5;
    border-radius: 42px;
    padding: 10px;
    background: linear-gradient(160deg, #1f2937, #0f172a);
    box-shadow:
      0 50px 80px -30px rgba(79, 70, 229, 0.35),
      0 30px 50px -20px rgba(0, 0, 0, 0.4);
    transform: rotate(-3deg);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .phone.floating {
    animation: float 7s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: rotate(-3deg) translateY(0); }
    50% { transform: rotate(-2deg) translateY(-10px); }
  }
  .phone:hover {
    animation-play-state: paused;
    transform: rotate(0deg) scale(1.02);
  }
  @media (prefers-reduced-motion: reduce) {
    .phone.floating { animation: none; }
  }
  .phone img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 32px;
    display: block;
  }
  .glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
    filter: blur(20px);
  }
  .glow-a {
    top: -100px;
    right: -200px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.22), transparent 60%);
    animation: drift 14s ease-in-out infinite;
  }
  .glow-b {
    bottom: -150px;
    left: -200px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(236, 72, 153, 0.14), transparent 60%);
    animation: drift 18s ease-in-out infinite reverse;
  }
  @keyframes drift {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(40px, 30px); }
  }
  @media (max-width: 768px) {
    .hero {
      padding: 3rem 1.5rem 4rem;
    }
    .inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }
    .actions {
      justify-content: center;
    }
    .badges {
      justify-content: center;
    }
    .phone {
      transform: rotate(0);
    }
  }
</style>

---
interface Props {
  appStoreUrl?: string;
}

const { appStoreUrl = '#' } = Astro.props;
---

<section class="hero">
  <div class="inner">
    <h1>
      <span class="accent">SRS</span> で単語を<br />
      確実に記憶するアプリ
    </h1>
    <p>
      フラッシュカード・AI クイズ・ながら学習・ウィジェット。<br />
      ロック画面からも復習できる、あなた専用の単語帳。
    </p>
    <a href={appStoreUrl} class="cta">App Store で入手</a>
  </div>
</section>

<style>
  .hero {
    padding: 6rem 2rem 4rem;
    text-align: center;
  }
  .inner {
    max-width: 720px;
    margin: 0 auto;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 1.5rem;
  }
  .accent {
    color: var(--accent);
  }
  p {
    font-size: 1.125rem;
    color: var(--muted);
    margin: 0 0 2rem;
  }
  .cta {
    display: inline-block;
    padding: 0.875rem 2rem;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    border-radius: 999px;
    font-weight: 600;
    transition: transform 0.2s ease;
  }
  .cta:hover {
    transform: translateY(-2px);
  }
</style>

---
interface Props {
  appStoreUrl?: string;
}

const { appStoreUrl = '#' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="inner">
    <div class="copy">
      <span class="eyebrow">SRS × AI × ウィジェット</span>
      <h1>
        <span class="accent">忘れる前に</span>、<br />
        ちょうどいい復習を。
      </h1>
      <p>
        フラッシュカード・AI クイズ・ロック画面ウィジェット。<br />
        科学的な間隔反復で、単語を確実に長期記憶へ。
      </p>
      <div class="actions">
        <a href={appStoreUrl} class="cta">App Store で入手</a>
        <a href="#features" class="ghost">機能を見る</a>
      </div>
    </div>
    <div class="mockup">
      <div class="phone">
        <img src={`${base}/screenshots/01_home.png`} alt="PeraTango ホーム画面" />
      </div>
    </div>
  </div>
  <div class="glow"></div>
</section>

<style>
  .hero {
    position: relative;
    padding: 5rem 2rem 6rem;
    overflow: hidden;
  }
  .inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .eyebrow {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 1.25rem;
  }
  h1 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }
  .accent {
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #ec4899 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .copy p {
    font-size: 1.1rem;
    color: var(--muted);
    margin: 0 0 2rem;
  }
  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .cta {
    display: inline-block;
    padding: 0.95rem 1.75rem;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    border-radius: 999px;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 10px 30px -10px color-mix(in srgb, var(--accent) 60%, transparent);
  }
  .cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px -12px color-mix(in srgb, var(--accent) 70%, transparent);
  }
  .ghost {
    display: inline-block;
    padding: 0.95rem 1.75rem;
    border: 1px solid var(--border);
    color: var(--fg);
    text-decoration: none;
    border-radius: 999px;
    font-weight: 600;
  }
  .mockup {
    display: flex;
    justify-content: center;
  }
  .phone {
    width: 280px;
    aspect-ratio: 9 / 19.5;
    border-radius: 42px;
    padding: 10px;
    background: linear-gradient(160deg, #1f2937, #0f172a);
    box-shadow:
      0 50px 80px -30px rgba(79, 70, 229, 0.35),
      0 30px 50px -20px rgba(0, 0, 0, 0.4);
    transform: rotate(-3deg);
    transition: transform 0.4s ease;
  }
  .phone:hover {
    transform: rotate(0deg);
  }
  .phone img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 32px;
    display: block;
  }
  .glow {
    position: absolute;
    top: -100px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(
      circle,
      rgba(124, 58, 237, 0.18),
      transparent 60%
    );
    pointer-events: none;
    z-index: -1;
  }
  @media (max-width: 768px) {
    .hero {
      padding: 3rem 1.5rem 4rem;
    }
    .inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }
    .actions {
      justify-content: center;
    }
    .phone {
      transform: rotate(0);
    }
  }
</style>

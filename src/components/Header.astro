---
const base = import.meta.env.BASE_URL;
---

<header>
  <nav>
    <a href={base} class="logo">PeraTango</a>
    <div class="links">
      <a href={`${base}#features`}>機能</a>
      <a href={`${base}#faq`}>FAQ</a>
      <a href={`${base}/support`}>サポート</a>
      <a href={`${base}/privacy`}>プライバシー</a>
    </div>
  </nav>
</header>

<style>
  header {
    padding: 1rem 2rem;
    border-bottom: 1px solid var(--border);
  }
  nav {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .logo {
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
    color: var(--fg);
  }
  .links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .links a {
    text-decoration: none;
    color: var(--muted);
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .links a:hover {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    header {
      padding: 0.75rem 1rem;
    }
    nav {
      gap: 0.5rem;
    }
    .logo {
      font-size: 1.1rem;
    }
    .links {
      gap: 0.85rem;
    }
    .links a {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 380px) {
    nav {
      flex-direction: column;
      align-items: flex-start;
    }
    .links {
      width: 100%;
      justify-content: space-between;
      gap: 0.5rem;
    }
  }
</style>

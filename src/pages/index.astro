---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import FeatureSection from '../components/FeatureSection.astro';
import StatsStrip from '../components/StatsStrip.astro';
import WidgetShowcase from '../components/WidgetShowcase.astro';
import Faq from '../components/Faq.astro';
import SupportNote from '../components/SupportNote.astro';
import Footer from '../components/Footer.astro';
import { faqItems } from '../data/faq';

const base = import.meta.env.BASE_URL;
const origin = 'https://hirokishingu.github.io';
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'PeraTango',
  operatingSystem: 'iOS 17+',
  applicationCategory: 'EducationalApplication',
  description:
    'SRS (間隔反復) とオンデバイス AI を組み合わせた、無料で広告なしの英単語学習 iOS アプリ。フラッシュカード・AI クイズ・発音練習・ホーム画面ウィジェット・Dynamic Island・Share Extension・単語図鑑に対応。',
  inLanguage: 'ja',
  url: `${origin}${base}`,
  image: `${origin}${base}/og-image.png`,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'JPY',
  },
};
---

<BaseLayout title="PeraTango - SRS で効率よく単語を覚える iOS アプリ">
  <Header />
  <main id="main-content">
    <Hero />

    <StatsStrip />

    <div id="features">
      <FeatureSection
        eyebrow="学習ロードマップ"
        title="目的別に、どこまで進めばいいかが分かる"
        description="TOEIC・大学受験・英検など、目的別のロードマップを用意。今どの段階にいて、次に何をすれば良いかがひと目で分かります。"
        imageBefore="/screenshots/01_home.webp"
        altBefore="ホーム画面"
        image="/screenshots/06_roadmap.webp"
        alt="学習ロードマップ画面"
        motion="float"
        tap="50,22"
      />

      <FeatureSection
        eyebrow="豊富な学習モード"
        title="フラッシュカード・AI クイズ・ながら学習"
        description="科学的な間隔反復(SRS)で復習タイミングを最適化。AI が生成するクイズや音声読み上げにも対応し、隙間時間でもしっかり定着します。"
        imageBefore="/screenshots/01_home.webp"
        altBefore="ホーム画面"
        image="/screenshots/04_study_select.webp"
        alt="学習モード選択画面"
        reverse
        motion="float"
        tap="50,97"
        note="※ AI クイズは Apple Intelligence 対応機種 (iPhone 15 Pro 以降) と iOS 26 以降が必要です。"
      />

      <FeatureSection
        eyebrow="発音練習 (オフライン対応)"
        title="口に出して、耳で覚える"
        description="オンデバイス音声認識で発音を採点。ネット不要・録音は端末外に出ません。✅/🟡/❌ の 3 段階判定と不正解時のリトライで、スペルだけでなく発音まで確かな知識にします。"
        imageBefore="/screenshots/07a_study_scrolled.webp"
        altBefore="学習モード選択画面（発音練習ボタン）"
        image="/screenshots/07b_pronunciation.webp"
        alt="発音練習セッション画面"
        motion="float"
        tap="50,87"
      />

      <WidgetShowcase />

      <FeatureSection
        eyebrow="単語帳管理"
        title="手持ちの単語帳を、そのままアプリに"
        description="プリセット・CSV インポート・OCR・ペースト貼り付けまで、単語追加の手段が豊富。デッキごとに進捗と習得率を管理できます。"
        imageBefore="/screenshots/02_decks.webp"
        altBefore="単語帳一覧"
        image="/screenshots/08_ocr_or_csv.webp"
        alt="単語リストから追加"
        motion="float"
        tap="92,8"
        note="※ カメラ OCR で単語を一括追加する機能は、サポーター登録のお礼としてお渡しする特典です。プリセット・CSV インポート・テキスト貼り付けはサポーター登録なしでご利用いただけます。"
      />

      <FeatureSection
        eyebrow="ワンタップで追加"
        title="他アプリから、気になった単語をそのまま"
        description="Safari・メール・メモなど、どこで英語を読んでいても、単語を長押し → 共有ボタンから PeraTango に送れます。AI が意味と例文を補完し、次にアプリを開いたとき自動で反映されます。"
        image="/screenshots/10_share_extension.webp"
        alt="Share Extension 画面"
        reverse
        motion="slide"
      />

      <FeatureSection
        eyebrow="コレクション要素"
        title="図鑑を埋める感覚で、語彙を広げる"
        description="覚えた単語は「未収録 → 銅 → 銀 → 金」と 4 段階にランクアップ。プリセット全単語の達成率が見えて、毎日の学習に目標が生まれます。学習中にランクが上がるとその場でお知らせ。"
        imageBefore="/screenshots/01_home.webp"
        altBefore="ホーム画面（図鑑カード）"
        image="/screenshots/09_dex.webp"
        alt="単語図鑑画面"
        motion="float"
        tap="50,48"
      />

      <FeatureSection
        eyebrow="進捗を見える化"
        title="続けたくなるダッシュボード"
        description="学習ストリーク、ヒートマップ、デッキ別の習得率。数字と色で学習が可視化され、毎日続ける後押しになります。1 日休んでもストリークを守る「フリーズチケット」も。"
        imageBefore="/screenshots/01_home.webp"
        altBefore="ホーム画面"
        image="/screenshots/05_stats.webp"
        alt="統計画面"
        reverse
        motion="float"
        tap="70,97"
      />

      <FeatureSection
        eyebrow="実績システム"
        title="続けるほど、ご褒美が増えていく"
        description="連続学習・累計レビュー数・特定デッキの達成度などに応じて、16 種類の実績がアンロックされます。今日の学習にもう一つ目的を。"
        image="/screenshots/11_achievements.webp"
        alt="実績画面"
        motion="float"
      />

      <FeatureSection
        eyebrow="PeraTango サポーター"
        title="応援していただいた方へ、感謝の気持ちとして"
        description="コア学習機能はすべて広告なし・無料でご利用いただけます。応援したい方が任意でサポーター登録をしてくださると、お礼として 10 種類のテーマ・代替アプリアイコン・カメラ OCR 単語追加・月次/年次 PDF レポート・CSV エクスポート・お気に入り単語マーク・タグ管理画面・デッキ別リマインダー・学習タイマーなど、合計 14 種類の特典を解放します。"
        image="/screenshots/12_supporter_benefits.webp"
        alt="サポーター特典まとめ画面"
        reverse
        motion="float"
        note="買い切り型・サブスクではありません。同じ Apple ID でいつでも復元できます。"
      />

      <FeatureSection
        eyebrow="サポーター特典 / 統計の深掘り"
        title="月次レポート・CSV エクスポート・完了予測"
        description="サポーター登録のお礼に、学習データを月次/年次 PDF レポートで書き出したり、Excel で開ける CSV にエクスポートできます。直近 30 日のペースから「現状ペースなら N 月までにこのデッキ完了」も予測表示。"
        image="/screenshots/16_stats_export.webp"
        alt="完了予測とデータ書き出し"
        motion="float"
      />

      <FeatureSection
        eyebrow="サポーター特典 / カスタマイズ"
        title="テーマ 10 種、学習画面の背景・カードめくり方"
        description="サポーター登録のお礼に、アクセントカラー・代替アプリアイコン込みのテーマ 10 種、カードのめくり方 4 種 (3D フリップ / フェード / スライド / なし)、学習画面の背景パターン 5 種、ポモドーロ式の学習タイマーなど、見た目と学習体験を細かくカスタマイズできます。"
        imageBefore="/screenshots/13_themes.webp"
        altBefore="テーマピッカー"
        image="/screenshots/14_study_customization.webp"
        alt="学習画面のカスタマイズ"
        reverse
        motion="float"
      />
    </div>
    <Faq />
    <SupportNote />
  </main>
  <Footer />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(softwareJsonLd)}
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(faqJsonLd)}
  />
</BaseLayout>
